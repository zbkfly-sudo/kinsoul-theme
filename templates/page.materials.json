    "craft": {
      "type": "kinsoul-craft-process",
      "blocks": {
        "step_1": {
          "type": "craft_step",
          "settings": {
            "image": "shopify://shop_images/1.jpg",
            "step_number": "01",
            "title": "Selected by Hand",
            "description": "We don't order in bulk. Each stone is held up to the light, turned, and considered — chosen for its color, pattern, and character. If it doesn't feel right, it doesn't make the cut. The stones you see in your bracelet were picked specifically for that piece. Our founder personally selects materials for every production run, evaluating each stone's translucency, surface texture, and how it interacts with the pearls and silver it will sit beside."
          }
        },
        "step_2": {
          "type": "craft_step",
          "settings": {
            "image": "shopify://shop_images/2.jpg",
            "step_number": "02",
            "title": "Assembled One Piece at a Time",
            "description": "Every bracelet is strung by hand — stone by stone, pearl by pearl. The arrangement isn't random; each piece is composed with balance and contrast in mind, considering how warm and cool tones play against each other on the wrist. Stones are tested for weight distribution so the bracelet hangs naturally. It's slow, quiet work — and that's the point. There is no assembly line in our California studio."
          }
        },
        "step_3": {
          "type": "craft_step",
          "settings": {
            "image": "shopify://shop_images/3.jpg",
            "step_number": "03",
            "title": "Checked Before It Leaves",
            "description": "Before it leaves, a fresh pair of eyes goes over every detail — the cord tension, the spacing, the way each stone sits. We verify the elastic stretch cord is secure and test the bracelet on the wrist for comfort and fit. Then it's photographed, paired with its gemstone meaning card, placed in our signature cotton-linen gift box with a cotton storage pouch, and sent on its way to you."
          }
        }
      },
