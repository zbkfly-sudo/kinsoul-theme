    "faq": {
      "type": "kinsoul-materials-faq",
      "blocks": {
        "q1": {
          "type": "faq_item",
          "settings": {
            "question": "Are your stones and pearls real?",
            "answer": "Yes — every gemstone and pearl in our bracelets is 100% natural. We never use synthetic, lab-created, or coated materials. Each bracelet ships with a gemstone meaning card that details the specific stones used in your piece."
          }
        },
        "q2": {
          "type": "faq_item",
          "settings": {
            "question": "Why does my bracelet look different from the product photo?",
            "answer": "Because we use genuine natural materials, every piece varies slightly in color, texture, shape, and size. An amethyst might lean more lavender or more violet; a baroque pearl will have its own unique form. This natural variation is a hallmark of authenticity — it's what makes your bracelet one of a kind."
          }
        },
        "q3": {
          "type": "faq_item",
          "settings": {
            "question": "What is a baroque pearl?",
            "answer": "A baroque pearl is a naturally formed pearl with an irregular, non-spherical shape. Unlike perfectly round cultured pearls, baroque pearls are valued for their organic character — each one has its own unique ridges, curves, and luster. We use baroque freshwater pearls as centerpieces in several Kinsoul bracelets."
          }
        },
        "q4": {
          "type": "faq_item",
          "settings": {
            "question": "How should I care for my natural gemstone bracelet?",
            "answer": "Wear your pearls often — they stay luminous when close to your skin. Put your bracelet on after perfume or lotion has settled, and remove it before washing hands or swimming. Avoid prolonged sunlight for amethyst and citrine. Store in the cotton pouch provided. If sterling silver darkens, a gentle polish with a soft cloth restores its shine. Visit our Client Care page for stone-specific care guides."
          }
        },
        "q5": {
          "type": "faq_item",
          "settings": {
            "question": "Will the sterling silver tarnish?",
            "answer": "S925 sterling silver may develop a natural patina over time — a soft darkening that many wearers appreciate as part of the bracelet's character. Some pieces, like Terra, feature intentionally antique-finished silver. A gentle polish with a soft cloth will restore the original luster whenever you prefer."
          }
        },
        "q6": {
          "type": "faq_item",
          "settings": {
            "question": "What cord do you use? Will it break?",
            "answer": "All Kinsoul bracelets use high-quality elastic stretch cord — no clasp needed, designed to slip on and off easily. The cord is tested for tension during our inspection process. A replacement cord is included free with every order, so you're covered for the long term."
          }
        }
      },
