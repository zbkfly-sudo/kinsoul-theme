            "icon_svg": "<svg width='40' height='40' viewBox='0 0 40 40' fill='none' xmlns='http://www.w3.org/2000/svg'><circle cx='20' cy='20' r='12' stroke='currentColor' stroke-width='1.5'/><ellipse cx='17' cy='17' rx='4' ry='3' stroke='currentColor' stroke-width='0.75' opacity='0.5'/></svg>"
