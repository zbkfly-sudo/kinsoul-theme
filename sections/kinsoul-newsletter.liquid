{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

<div
  class="kinsoul-newsletter-wrap section-{{ section.id }} color-{{ color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    <div class="kinsoul-newsletter__inner" data-kinsoul-reveal="up">
      {%- if section.settings.subheading != blank -%}
        <p class="kinsoul-newsletter__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="kinsoul-newsletter__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <hr class="kinsoul-divider">

      {%- if section.settings.description != blank -%}
        <p class="kinsoul-newsletter__description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'kinsoul-newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <div class="kinsoul-newsletter__form">
          <input
            type="email"
            name="contact[email]"
            id="kinsoul-newsletter-email"
            class="kinsoul-newsletter__input"
            placeholder="{{ section.settings.placeholder }}"
            required
            autocomplete="email"
            aria-label="Email"
          >
          <button
            type="submit"
            class="kinsoul-newsletter__button"
          >
            {{ section.settings.button_text }}
          </button>
        </div>

        {%- if form.posted_successfully? -%}
          <p class="kinsoul-newsletter__success">
            {{ section.settings.success_message }}
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          <p class="kinsoul-newsletter__error">
            {{ form.errors.translated_fields['email'] | capitalize }}
            {{ form.errors.messages['email'] }}
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .kinsoul-newsletter__inner {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .kinsoul-newsletter__subheading {
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--kinsoul-accent, #7B6B5D);
    margin-bottom: 1rem;
  }

  .kinsoul-newsletter__heading {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--color-foreground-heading);
    letter-spacing: 0.03em;
    margin: 0;
  }

  .kinsoul-newsletter__description {
    font-size: 0.875rem;
    color: var(--kinsoul-muted, #8A8278);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .kinsoul-newsletter__form {
    display: flex;
    gap: 0;
    max-width: 460px;
    margin: 0 auto;
  }

  .kinsoul-newsletter__input {
    flex: 1;
    background: transparent;
    border: 1px solid var(--kinsoul-border, #E0D8CE);
    color: var(--color-foreground-heading);
    padding: 0.875rem 1.25rem;
    font-family: var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    transition: border-color 0.3s ease;
  }

  .kinsoul-newsletter__input:focus {
    border-color: var(--kinsoul-accent, #7B6B5D);
    outline: none;
  }

  .kinsoul-newsletter__input::placeholder {
    color: var(--kinsoul-muted, #8A8278);
  }

  .kinsoul-newsletter__button {
    background: var(--color-primary-button-background, #2C2C2C);
    color: var(--color-primary-button-text, #F9F6F1);
    border: 1px solid var(--color-primary-button-border, #2C2C2C);
    padding: 0.875rem 2rem;
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .kinsoul-newsletter__button:hover {
    background: var(--color-primary-button-hover-background, #3C3C3C);
    border-color: var(--color-primary-button-hover-border, #3C3C3C);
  }

  .kinsoul-newsletter__success {
    color: var(--kinsoul-accent, #7B6B5D);
    font-size: 0.875rem;
    margin-top: 1rem;
  }

  .kinsoul-newsletter__error {
    color: #cc4444;
    font-size: 0.875rem;
    margin-top: 1rem;
  }

  @media screen and (max-width: 749px) {
    .kinsoul-newsletter__form {
      flex-direction: column;
      gap: 0.75rem;
    }

    .kinsoul-newsletter__button {
      padding: 0.875rem 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "kinsoul-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Stay Connected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Inner Circle"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "First access to new drops, stone stories & styling notes — delivered to your inbox."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for subscribing."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
