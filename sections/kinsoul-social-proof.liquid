{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign total = section.blocks.size
-%}

<div
  class="kinsoul-social-proof-section section-{{ section.id }} color-{{ color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="kinsoul-social-proof__header">
        {%- if section.settings.subheading != blank -%}
          <p class="kinsoul-social-proof__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <h2 class="kinsoul-social-proof__title">{{ section.settings.heading }}</h2>
        <hr class="kinsoul-divider">
      </div>
    {%- endif -%}

    <div class="kinsoul-reviews-carousel" id="kinsoul-carousel-{{ section.id }}">
      <div class="kinsoul-reviews-carousel__track" id="kinsoul-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="kinsoul-review-slide" {{ block.shopify_attributes }}>
            <div class="kinsoul-review-slide__image">
              {%- if block.settings.image != blank -%}
                {%- assign review_alt = 'Customer review - ' | append: block.settings.author | append: ' - ' | append: block.settings.product_name -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    decoding: 'async',
                    fetchpriority: 'low',
                    widths: '300, 500, 800',
                    sizes: '(max-width: 749px) 90vw, (max-width: 1099px) 45vw, 30vw',
                    class: 'kinsoul-review-slide__img',
                    alt: review_alt
                }}
              {%- else -%}
                <div class="kinsoul-review-slide__img-placeholder"></div>
              {%- endif -%}
            </div>
            <div class="kinsoul-review-slide__content">
              <div class="kinsoul-review-slide__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                {%- for i in (1..5) -%}
                  {%- if i <= block.settings.rating -%}
                    &#9733;
                  {%- else -%}
                    &#9734;
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- if block.settings.review_text != blank -%}
                <p class="kinsoul-review-slide__text">"{{ block.settings.review_text }}"</p>
              {%- endif -%}
              {%- if block.settings.author != blank -%}
                <p class="kinsoul-review-slide__author">— {{ block.settings.author }}</p>
              {%- endif -%}
              {%- if block.settings.product_name != blank -%}
                <p class="kinsoul-review-slide__product">{{ block.settings.product_name }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if total > 1 -%}
        <div class="kinsoul-reviews-carousel__controls">
          <button class="kinsoul-reviews-carousel__btn kinsoul-reviews-carousel__btn--prev" aria-label="Previous review" onclick="kinsoulCarousel('{{ section.id }}', -1)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="kinsoul-reviews-carousel__dots" id="kinsoul-dots-{{ section.id }}">
            {%- for block in section.blocks -%}
              <button
                class="kinsoul-reviews-carousel__dot{% if forloop.first %} kinsoul-reviews-carousel__dot--active{% endif %}"
                aria-label="Go to review {{ forloop.index }}"
                onclick="kinsoulCarouselGo('{{ section.id }}', {{ forloop.index0 }})"
              ></button>
            {%- endfor -%}
          </div>
          <button class="kinsoul-reviews-carousel__btn kinsoul-reviews-carousel__btn--next" aria-label="Next review" onclick="kinsoulCarousel('{{ section.id }}', 1)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function() {
    var currentSlide = {};
    var autoplayTimers = {};
    var isVisible = {};
    var isPageVisible = !document.hidden;

    function getSlidesPerView(carousel) {
      return parseInt(getComputedStyle(carousel).getPropertyValue('--slides-per-view')) || 1;
    }

    function getMaxIndex(track, carousel) {
      return Math.max(0, track.children.length - getSlidesPerView(carousel));
    }

    window.kinsoulCarouselGo = function(sectionId, index) {
      var carousel = document.getElementById('kinsoul-carousel-' + sectionId);
      var track = document.getElementById('kinsoul-track-' + sectionId);
      var dots = document.getElementById('kinsoul-dots-' + sectionId);
      if (!track || !carousel) return;

      var slides = track.children;
      if (slides.length === 0) return;

      var maxIndex = getMaxIndex(track, carousel);
      if (index < 0) index = maxIndex;
      if (index > maxIndex) index = 0;

      currentSlide[sectionId] = index;

      var slideWidth = slides[0].offsetWidth;
      var gap = parseFloat(getComputedStyle(track).getPropertyValue('gap')) || 0;
      track.style.transform = 'translateX(-' + (index * (slideWidth + gap)) + 'px)';

      if (dots) {
        for (var i = 0; i < dots.children.length; i++) {
          dots.children[i].classList.toggle('kinsoul-reviews-carousel__dot--active', i === index);
        }
      }
    };

    window.kinsoulCarousel = function(sectionId, direction) {
      kinsoulCarouselGo(sectionId, (currentSlide[sectionId] || 0) + direction);
    };

    function startAutoplay(sectionId) {
      if (autoplayTimers[sectionId] || !isVisible[sectionId] || !isPageVisible) return;
      autoplayTimers[sectionId] = setInterval(function() {
        kinsoulCarousel(sectionId, 1);
      }, 4500);
    }

    function stopAutoplay(sectionId) {
      if (autoplayTimers[sectionId]) {
        clearInterval(autoplayTimers[sectionId]);
        autoplayTimers[sectionId] = null;
      }
    }

    /* Pause all carousels when tab is hidden */
    document.addEventListener('visibilitychange', function() {
      isPageVisible = !document.hidden;
      Object.keys(currentSlide).forEach(function(id) {
        if (isPageVisible && isVisible[id]) startAutoplay(id);
        else stopAutoplay(id);
      });
    });

    /* Throttled resize handler (shared, single listener) */
    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        Object.keys(currentSlide).forEach(function(sectionId) {
          var carousel = document.getElementById('kinsoul-carousel-' + sectionId);
          var track = carousel && carousel.querySelector('.kinsoul-reviews-carousel__track');
          if (!track || !carousel) return;
          var maxIndex = getMaxIndex(track, carousel);
          if (currentSlide[sectionId] > maxIndex) currentSlide[sectionId] = 0;
          kinsoulCarouselGo(sectionId, currentSlide[sectionId]);
        });
      }, 200);
    });

    function initCarousel(carousel) {
      var sectionId = carousel.id.replace('kinsoul-carousel-', '');
      var track = carousel.querySelector('.kinsoul-reviews-carousel__track');
      currentSlide[sectionId] = 0;
      isVisible[sectionId] = false;

      /* Only autoplay when section is in viewport */
      if ('IntersectionObserver' in window) {
        new IntersectionObserver(function(entries) {
          isVisible[sectionId] = entries[0].isIntersecting;
          if (entries[0].isIntersecting) startAutoplay(sectionId);
          else stopAutoplay(sectionId);
        }, { rootMargin: '100px' }).observe(carousel);
      } else {
        isVisible[sectionId] = true;
        startAutoplay(sectionId);
      }

      /* Pause on hover */
      carousel.addEventListener('mouseenter', function() { stopAutoplay(sectionId); });
      carousel.addEventListener('mouseleave', function() { startAutoplay(sectionId); });

      /* Touch swipe */
      var startX = 0;
      track.addEventListener('touchstart', function(e) {
        startX = e.touches[0].clientX;
        stopAutoplay(sectionId);
      }, { passive: true });
      track.addEventListener('touchend', function(e) {
        var diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) kinsoulCarousel(sectionId, diff > 0 ? 1 : -1);
        startAutoplay(sectionId);
      }, { passive: true });
    }

    document.querySelectorAll('.kinsoul-reviews-carousel').forEach(initCarousel);
  })();
</script>

{% stylesheet %}
  .kinsoul-social-proof__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .kinsoul-social-proof__subheading {
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--kinsoul-accent, #7B6B5D);
    margin-bottom: 1rem;
  }

  .kinsoul-social-proof__title {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    color: var(--color-foreground-heading);
    letter-spacing: 0.03em;
    margin: 0;
  }

  /* Carousel — multi-card view */
  .kinsoul-reviews-carousel {
    position: relative;
    overflow: hidden;
    --slides-per-view: 3;
    --slide-gap: 1.75rem;
  }

  .kinsoul-reviews-carousel__track {
    display: flex;
    gap: var(--slide-gap);
    transition: transform 0.7s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: transform;
  }

  .kinsoul-review-slide {
    flex: 0 0 calc((100% - (var(--slides-per-view) - 1) * var(--slide-gap)) / var(--slides-per-view));
    display: flex;
    flex-direction: column;
    background: var(--kinsoul-bg, #FFFFFF);
    border: 1px solid var(--kinsoul-border, #EAE3D9);
    overflow: hidden;
  }

  /* Image */
  .kinsoul-review-slide__image {
    overflow: hidden;
    width: 100%;
  }

  .kinsoul-review-slide__img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    transition: transform 0.7s ease;
  }

  .kinsoul-review-slide:hover .kinsoul-review-slide__img {
    transform: scale(1.03);
  }

  .kinsoul-review-slide__img-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--kinsoul-bg-alt, #F0EDE8);
  }

  /* Content */
  .kinsoul-review-slide__content {
    padding: 1.75rem 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .kinsoul-review-slide__stars {
    color: var(--kinsoul-accent, #7B6B5D);
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
    letter-spacing: 0.15em;
  }

  .kinsoul-review-slide__text {
    font-family: var(--font-heading--family), serif;
    font-style: italic;
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    line-height: 1.65;
    color: var(--kinsoul-heading, #2C2C2C);
    margin: 0 0 1.25rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .kinsoul-review-slide__author {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--kinsoul-text, #4A4A4A);
    margin: 0 0 0.25rem;
  }

  .kinsoul-review-slide__product {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--kinsoul-accent, #7B6B5D);
    margin: 0;
  }

  /* Controls */
  .kinsoul-reviews-carousel__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .kinsoul-reviews-carousel__btn {
    background: none;
    border: 1px solid var(--kinsoul-border, #E0D8CE);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--kinsoul-heading, #2C2C2C);
    transition: border-color 0.25s ease, color 0.25s ease;
  }

  .kinsoul-reviews-carousel__btn:hover {
    border-color: var(--kinsoul-accent, #7B6B5D);
    color: var(--kinsoul-accent, #7B6B5D);
  }

  .kinsoul-reviews-carousel__dots {
    display: flex;
    gap: 0.5rem;
  }

  .kinsoul-reviews-carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid var(--kinsoul-border, #E0D8CE);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }

  .kinsoul-reviews-carousel__dot--active {
    background: var(--kinsoul-accent, #7B6B5D);
    border-color: var(--kinsoul-accent, #7B6B5D);
  }

  .kinsoul-reviews-carousel__dot:hover {
    border-color: var(--kinsoul-accent, #7B6B5D);
  }

  /* Tablet — 2 cards per view */
  @media screen and (max-width: 1099px) and (min-width: 750px) {
    .kinsoul-reviews-carousel {
      --slides-per-view: 2;
      --slide-gap: 1.25rem;
    }
  }

  /* Mobile — 1 card per view */
  @media screen and (max-width: 749px) {
    .kinsoul-reviews-carousel {
      --slides-per-view: 1;
      --slide-gap: 1rem;
    }

    .kinsoul-social-proof__header {
      margin-bottom: 2.5rem;
    }

    .kinsoul-review-slide__content {
      padding: 1.5rem 1.25rem 1.75rem;
    }

    .kinsoul-review-slide__text {
      -webkit-line-clamp: 8;
    }

    .kinsoul-reviews-carousel__controls {
      margin-top: 1.5rem;
    }

    .kinsoul-reviews-carousel__btn {
      width: 36px;
      height: 36px;
    }

    /* Hide individual dots on mobile if many reviews — show simplified */
    .kinsoul-reviews-carousel__dots {
      max-width: 60vw;
      overflow: hidden;
      flex-wrap: nowrap;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Social Proof",
  "tag": "section",
  "class": "kinsoul-social-proof-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Worn & Loved"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Review image",
          "info": "Product or lifestyle photo. Recommended: 600×750px (4:5 ratio)."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Proof",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "I wear my Serenity bracelet almost every day. The purple is deeper in person than in the photos, which I actually love. Really well made.",
            "author": "Sarah M. · March 2026",
            "product_name": "Serenity Bracelet"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "Bought the Aura for my sister's birthday. She literally texted me a photo within 5 minutes of opening it. The packaging was beautiful too — didn't need to wrap it.",
            "author": "Emily R. · February 2026",
            "product_name": "Aura Bracelet"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 4,
            "review_text": "Honestly I wasn't sure about spending this much on a bracelet, but the Ember is worth it. The red stones catch the light in a way that gets compliments. Only giving 4 stars because I wish they made more styles — I'd buy another one in a heartbeat!",
            "author": "Jessica T. · January 2026",
            "product_name": "Ember Bracelet"
          }
        }
      ]
    }
  ]
}
{% endschema %}
