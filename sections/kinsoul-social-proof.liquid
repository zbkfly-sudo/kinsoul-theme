{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

<div
  class="kinsoul-social-proof-section section-{{ section.id }} color-{{ color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="kinsoul-social-proof__header">
        {%- if section.settings.subheading != blank -%}
          <p class="kinsoul-social-proof__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <h2 class="kinsoul-social-proof__title">{{ section.settings.heading }}</h2>
        <hr class="kinsoul-divider">
      </div>
    {%- endif -%}

    <div class="kinsoul-reviews">
      {%- for block in section.blocks -%}
        <div class="kinsoul-review-card" {{ block.shopify_attributes }}>
          <div class="kinsoul-review-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.rating -%}
                &#9733;
              {%- else -%}
                &#9734;
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if block.settings.review_text != blank -%}
            <p class="kinsoul-review-card__text">"{{ block.settings.review_text }}"</p>
          {%- endif -%}

          {%- if block.settings.author != blank -%}
            <p class="kinsoul-review-card__author">— {{ block.settings.author }}</p>
          {%- endif -%}

          {%- if block.settings.product_name != blank -%}
            <p class="kinsoul-review-card__product">{{ block.settings.product_name }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .kinsoul-social-proof__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .kinsoul-social-proof__subheading {
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--kinsoul-accent, #7B6B5D);
    margin-bottom: 1rem;
  }

  .kinsoul-social-proof__title {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    color: var(--color-foreground-heading);
    letter-spacing: 0.03em;
    margin: 0;
  }

  .kinsoul-review-card__product {
    font-size: 0.75rem;
    color: var(--kinsoul-accent, #7B6B5D);
    margin-top: 0.5rem;
    letter-spacing: 0.05em;
  }

  @media screen and (max-width: 749px) {
    .kinsoul-social-proof__header {
      margin-bottom: 2.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Social Proof",
  "tag": "section",
  "class": "kinsoul-social-proof-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Worn & Loved"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "The quality is incredible. I wear it every day and it still looks brand new."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Proof",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "The amethyst bracelet is stunning — each stone has its own character. It feels special every time I put it on.",
            "author": "Sarah M.",
            "product_name": "Freeform Amethyst Bracelet"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "I bought the Aura Balance as a gift and my sister hasn't taken it off since. Beautiful craftsmanship and fast shipping.",
            "author": "Emily R.",
            "product_name": "Aura Balance Bracelet"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "The natural pearls and stones are gorgeous. You can really tell the difference from mass-produced jewelry.",
            "author": "Jessica T.",
            "product_name": "Persian Red Agate Bracelet"
          }
        }
      ]
    }
  ]
}
{% endschema %}
