{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

<div
  class="puraperla-newsletter section-{{ section.id }} color-{{ color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    <div class="puraperla-newsletter__inner">
      {%- if section.settings.subheading != blank -%}
        <p class="puraperla-newsletter__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="puraperla-newsletter__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <hr class="puraperla-gold-divider">

      {%- if section.settings.description != blank -%}
        <p class="puraperla-newsletter__description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <div class="puraperla-newsletter__form">
          <input
            type="email"
            name="contact[email]"
            id="newsletter-email"
            class="puraperla-newsletter__input"
            placeholder="{{ section.settings.placeholder }}"
            required
            autocomplete="email"
            aria-label="Email"
          >
          <button
            type="submit"
            class="puraperla-newsletter__button"
          >
            {{ section.settings.button_text }}
          </button>
        </div>

        {%- if form.posted_successfully? -%}
          <p class="puraperla-newsletter__success">
            {{ section.settings.success_message }}
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          <p class="puraperla-newsletter__error">
            {{ form.errors.translated_fields['email'] | capitalize }}
            {{ form.errors.messages['email'] }}
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .puraperla-newsletter__inner {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .puraperla-newsletter__subheading {
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--puraperla-gold, #C9A96E);
    margin-bottom: 1rem;
  }

  .puraperla-newsletter__heading {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--color-foreground-heading);
    letter-spacing: 0.05em;
    margin: 0;
  }

  .puraperla-newsletter__description {
    font-size: 0.875rem;
    color: var(--puraperla-muted, #9A958F);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .puraperla-newsletter__form {
    display: flex;
    gap: 0;
    max-width: 460px;
    margin: 0 auto;
  }

  .puraperla-newsletter__input {
    flex: 1;
    background: transparent;
    border: 1px solid var(--puraperla-muted, #9A958F);
    color: var(--color-foreground-heading);
    padding: 0.875rem 1.25rem;
    font-family: var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    transition: border-color 0.3s ease;
  }

  .puraperla-newsletter__input:focus {
    border-color: var(--puraperla-gold, #C9A96E);
    outline: none;
  }

  .puraperla-newsletter__input::placeholder {
    color: var(--puraperla-muted, #9A958F);
  }

  .puraperla-newsletter__button {
    background: var(--puraperla-gold, #C9A96E);
    color: #0A0A0A;
    border: 1px solid var(--puraperla-gold, #C9A96E);
    padding: 0.875rem 2rem;
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .puraperla-newsletter__button:hover {
    background: var(--puraperla-gold-hover, #D4B97E);
    border-color: var(--puraperla-gold-hover, #D4B97E);
  }

  .puraperla-newsletter__success {
    color: var(--puraperla-gold, #C9A96E);
    font-size: 0.875rem;
    margin-top: 1rem;
  }

  .puraperla-newsletter__error {
    color: #cc4444;
    font-size: 0.875rem;
    margin-top: 1rem;
  }

  .puraperla-gold-divider {
    width: 60px;
    height: 1px;
    background: var(--puraperla-gold, #C9A96E);
    margin: 1.5rem auto;
    border: none;
  }

  @media screen and (max-width: 749px) {
    .puraperla-newsletter__form {
      flex-direction: column;
      gap: 0.75rem;
    }

    .puraperla-newsletter__button {
      padding: 0.875rem 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "puraperla-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Stay Connected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Inner Circle"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Be the first to discover new collections, exclusive offers, and the stories behind our stones."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for subscribing."
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
