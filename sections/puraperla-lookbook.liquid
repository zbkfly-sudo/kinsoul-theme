{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign section_width = section.settings.section_width
-%}

<div
  class="puraperla-lookbook section-{{ section.id }} color-{{ color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="{{ section_width }}">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'product_showcase' -%}
          {%- liquid
            assign layout = block.settings.layout
            assign image = block.settings.image
            assign heading = block.settings.heading
            assign subheading = block.settings.subheading
            assign price_text = block.settings.price_text
            assign link_url = block.settings.link_url
            assign link_text = block.settings.link_text
          -%}

          <div
            class="puraperla-lookbook__item puraperla-lookbook__item--{{ layout }}"
            style="
              margin-bottom: {{ block.settings.spacing }}px;
            "
            {{ block.shopify_attributes }}
          >
            <div class="puraperla-lookbook__media">
              {%- if image != blank -%}
                {{
                  image
                  | image_url: width: 1600
                  | image_tag:
                    loading: 'lazy',
                    widths: '400, 600, 800, 1000, 1200, 1400, 1600',
                    sizes: '(max-width: 749px) 100vw, 55vw',
                    class: 'puraperla-lookbook__image'
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'puraperla-lookbook__placeholder' }}
              {%- endif -%}
            </div>

            <div class="puraperla-lookbook__content">
              <div class="puraperla-lookbook__content-inner">
                {%- if subheading != blank -%}
                  <p class="puraperla-lookbook__subheading">{{ subheading }}</p>
                {%- endif -%}

                {%- if heading != blank -%}
                  <h2 class="puraperla-lookbook__heading">{{ heading }}</h2>
                {%- endif -%}

                <hr class="puraperla-gold-divider">

                {%- if price_text != blank -%}
                  <p class="puraperla-lookbook__price">{{ price_text }}</p>
                {%- endif -%}

                {%- if link_url != blank and link_text != blank -%}
                  <a href="{{ link_url }}" class="puraperla-lookbook__link">
                    {{ link_text }}
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .puraperla-lookbook__item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: center;
    overflow: hidden;
  }

  .puraperla-lookbook__item--image-right {
    direction: rtl;
  }

  .puraperla-lookbook__item--image-right > * {
    direction: ltr;
  }

  .puraperla-lookbook__media {
    overflow: hidden;
    position: relative;
    aspect-ratio: 4 / 5;
  }

  .puraperla-lookbook__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .puraperla-lookbook__item:hover .puraperla-lookbook__image {
    transform: scale(1.03);
  }

  .puraperla-lookbook__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .puraperla-lookbook__content {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    min-height: 100%;
  }

  .puraperla-lookbook__content-inner {
    text-align: center;
    max-width: 400px;
  }

  .puraperla-lookbook__subheading {
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--puraperla-gold, #C9A96E);
    margin-bottom: 1.5rem;
  }

  .puraperla-lookbook__heading {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-foreground-heading);
    margin-bottom: 0;
    letter-spacing: 0.05em;
  }

  .puraperla-lookbook__price {
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 1.1rem;
    color: var(--puraperla-gold, #C9A96E);
    letter-spacing: 0.1em;
    margin-bottom: 2rem;
  }

  .puraperla-lookbook__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
    text-decoration: none;
    transition: color 0.3s ease, gap 0.3s ease;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.25rem;
  }

  .puraperla-lookbook__link:hover {
    color: var(--puraperla-gold, #C9A96E);
    gap: 0.75rem;
  }

  .puraperla-lookbook__link svg {
    transition: transform 0.3s ease;
  }

  .puraperla-lookbook__link:hover svg {
    transform: translateX(4px);
  }

  .puraperla-gold-divider {
    width: 60px;
    height: 1px;
    background: var(--puraperla-gold, #C9A96E);
    margin: 1.5rem auto;
    border: none;
  }

  /* Mobile: stack vertically */
  @media screen and (max-width: 749px) {
    .puraperla-lookbook__item {
      grid-template-columns: 1fr;
    }

    .puraperla-lookbook__item--image-right {
      direction: ltr;
    }

    .puraperla-lookbook__media {
      aspect-ratio: 3 / 4;
    }

    .puraperla-lookbook__content {
      padding: 2.5rem 1.5rem;
    }

    .puraperla-lookbook__heading {
      font-size: 1.75rem;
    }
  }

  /* Tablet */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .puraperla-lookbook__content {
      padding: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Lookbook Showcase",
  "tag": "section",
  "class": "puraperla-lookbook-section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "full-width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "product_showcase",
      "name": "Product Showcase",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Layout",
          "options": [
            { "value": "image-left", "label": "Image left" },
            { "value": "image-right", "label": "Image right" }
          ],
          "default": "image-left"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Natural Gemstone"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Crimson Agate Bracelet"
        },
        {
          "type": "text",
          "id": "price_text",
          "label": "Price text",
          "default": "From $189"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "View Details"
        },
        {
          "type": "range",
          "id": "spacing",
          "label": "Bottom spacing",
          "min": 0,
          "max": 80,
          "step": 4,
          "unit": "px",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook Showcase",
      "blocks": [
        {
          "type": "product_showcase",
          "settings": {
            "layout": "image-left",
            "subheading": "Persian Red Agate",
            "heading": "Flame & Pearl",
            "price_text": "From $189"
          }
        },
        {
          "type": "product_showcase",
          "settings": {
            "layout": "image-right",
            "subheading": "Botswana Agate",
            "heading": "Earth Whisper",
            "price_text": "From $169"
          }
        }
      ]
    }
  ]
}
{% endschema %}
