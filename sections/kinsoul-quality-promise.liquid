{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

<div
  class="kinsoul-quality section-{{ section.id }} color-{{ color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="kinsoul-quality__header" data-kinsoul-reveal="up">
        {%- if section.settings.subheading != blank -%}
          <p class="kinsoul-quality__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <h2 class="kinsoul-quality__title">{{ section.settings.heading }}</h2>
        <hr class="kinsoul-divider">
      </div>
    {%- endif -%}

    <div class="kinsoul-quality__grid" data-kinsoul-stagger="120">
      {%- for block in section.blocks -%}
        <div class="kinsoul-quality__item" data-kinsoul-stagger-child {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="kinsoul-quality__icon">{{ block.settings.icon }}</div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="kinsoul-quality__item-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="kinsoul-quality__item-text">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .kinsoul-quality__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .kinsoul-quality__subheading {
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--kinsoul-accent, #7B6B5D);
    margin-bottom: 1rem;
  }

  .kinsoul-quality__title {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    color: var(--color-foreground-heading);
    letter-spacing: 0.03em;
    margin: 0;
  }

  .kinsoul-quality__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .kinsoul-quality__item {
    text-align: center;
    padding: 2rem 1.25rem;
    border: 1px solid var(--kinsoul-border, #E0D8CE);
    border-radius: var(--kinsoul-radius-soft, 2px);
    transition: box-shadow 0.3s ease;
  }

  .kinsoul-quality__item:hover {
    box-shadow: var(--kinsoul-shadow-soft, 0 4px 24px rgba(44, 44, 44, 0.06));
  }

  .kinsoul-quality__icon {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--kinsoul-accent, #7B6B5D);
  }

  .kinsoul-quality__item-title {
    font-family: var(--font-heading--family), serif;
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--kinsoul-heading, #2C2C2C);
    letter-spacing: 0.03em;
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .kinsoul-quality__item-text {
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--kinsoul-text, #4A4A4A);
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .kinsoul-quality__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 449px) {
    .kinsoul-quality__grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .kinsoul-quality__item {
      padding: 1.5rem 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Quality Promise",
  "tag": "section",
  "class": "kinsoul-quality-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our Promise"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Every Order Includes"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "promise_item",
      "name": "Promise Item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (text or emoji)",
          "default": "◆"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Natural"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Every gemstone and pearl is genuine — never synthetic, never lab-created."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quality Promise",
      "blocks": [
        {
          "type": "promise_item",
          "settings": {
            "title": "100% Natural",
            "description": "Every gemstone and pearl is genuine — never synthetic, never lab-created."
          }
        },
        {
          "type": "promise_item",
          "settings": {
            "title": "Certificate of Authenticity",
            "description": "Each bracelet ships with a gemstone meaning card on letterpress cotton paper."
          }
        },
        {
          "type": "promise_item",
          "settings": {
            "title": "Replacement Cord",
            "description": "A spare elastic stretch cord is included with every order, free of charge."
          }
        },
        {
          "type": "promise_item",
          "settings": {
            "title": "Gift-Ready Packaging",
            "description": "Signature cotton-linen gift box, microsuede lining, and cotton storage pouch."
          }
        }
      ]
    }
  ]
}
{% endschema %}
