{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

<div
  class="kinsoul-gifting-section section-{{ section.id }} color-{{ color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="kinsoul-gifting-section__header">
        {%- if section.settings.subheading != blank -%}
          <p class="kinsoul-gifting-section__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <h2 class="kinsoul-gifting-section__title">{{ section.settings.heading }}</h2>
        <hr class="kinsoul-divider">
      </div>
    {%- endif -%}

    <div class="kinsoul-service-grid">
      {%- for block in section.blocks -%}
        <div class="kinsoul-service-card" {{ block.shopify_attributes }}>
          {%- if block.settings.link_url != blank -%}
            <a href="{{ block.settings.link_url }}" class="kinsoul-service-card__link-overlay" aria-label="{{ block.settings.title }}"></a>
          {%- endif -%}

          {%- if block.settings.icon_svg != blank -%}
            <div class="kinsoul-service-card__icon">
              {{ block.settings.icon_svg }}
            </div>
          {%- endif -%}

          {%- if block.settings.title != blank -%}
            <h3 class="kinsoul-service-card__title">{{ block.settings.title }}</h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="kinsoul-service-card__text">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .kinsoul-gifting-section__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .kinsoul-gifting-section__subheading {
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--kinsoul-accent, #7B6B5D);
    margin-bottom: 1rem;
  }

  .kinsoul-gifting-section__title {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    color: var(--color-foreground-heading);
    letter-spacing: 0.03em;
    margin: 0;
  }

  .kinsoul-service-card {
    position: relative;
  }

  .kinsoul-service-card__link-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    text-decoration: none;
  }

  @media screen and (max-width: 749px) {
    .kinsoul-gifting-section__header {
      margin-bottom: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gifting & Service",
  "tag": "section",
  "class": "kinsoul-gifting-service-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "We're Here to Help"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gifting & Client Care"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "service_card",
      "name": "Service Card",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG code"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Gift-Ready"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Every order arrives beautifully packaged."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gifting & Service",
      "blocks": [
        {
          "type": "service_card",
          "settings": {
            "title": "Gift-Ready Packaging",
            "description": "Every piece arrives in a signature box, ready to gift or to keep for yourself.",
            "icon_svg": "<svg width='32' height='32' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='20 12 20 22 4 22 4 12'/><rect x='2' y='7' width='20' height='5'/><line x1='12' y1='22' x2='12' y2='7'/><path d='M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z'/><path d='M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z'/></svg>"
          }
        },
        {
          "type": "service_card",
          "settings": {
            "title": "Size Guidance",
            "description": "Not sure about fit? Our bracelet sizing guide makes choosing easy.",
            "icon_svg": "<svg width='32' height='32' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><line x1='2' y1='12' x2='22' y2='12'/><path d='M6 12v-2'/><path d='M10 12V8'/><path d='M14 12V8'/><path d='M18 12v-2'/></svg>"
          }
        },
        {
          "type": "service_card",
          "settings": {
            "title": "Client Care",
            "description": "Shipping, returns, care instructions — everything you need in one place.",
            "icon_svg": "<svg width='32' height='32' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z'/></svg>"
          }
        },
        {
          "type": "service_card",
          "settings": {
            "title": "Contact Us",
            "description": "Questions about a piece, a gift, or your order? We're here to help.",
            "icon_svg": "<svg width='32' height='32' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z'/><polyline points='22,6 12,13 2,6'/></svg>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
