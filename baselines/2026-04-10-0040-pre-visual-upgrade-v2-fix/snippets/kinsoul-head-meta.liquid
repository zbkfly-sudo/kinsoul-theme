{% comment %}
  Kinsoul Energy — Additional head meta tags for SEO + performance + UX
  Includes:
    - Brand theme-color (status bar tint on mobile Safari/Chrome)
    - Apple touch icon (iOS home screen icon)
    - Preconnect / DNS-prefetch (LCP performance boost)
    - format-detection (prevent iOS auto-linking phone numbers)
    - referrer-policy
    - Robots / language hints
{% endcomment %}

{%- comment %} Theme color for mobile browser status bar — brand warm brown {% endcomment -%}
<meta name="theme-color" content="#7B6B5D">
<meta name="msapplication-TileColor" content="#7B6B5D">
<meta name="color-scheme" content="light">

{%- comment %} Apple touch icon (iOS home screen) {% endcomment -%}
{%- if settings.logo != blank -%}
  <link rel="apple-touch-icon" sizes="180x180" href="{{ settings.logo | image_url: width: 180, height: 180 }}">
{%- endif -%}

{%- comment %} Prevent iOS from auto-formatting phone numbers / addresses {% endcomment -%}
<meta name="format-detection" content="telephone=no, address=no, email=no">

{%- comment %} Standard robots directive (explicit for clarity) {% endcomment -%}
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1">

{%- comment %} Author / publisher attribution {% endcomment -%}
<meta name="author" content="Kinsoul Energy">
<meta name="publisher" content="Kinsoul Energy">

{%- comment %} Performance: preconnect to critical third-party origins {% endcomment -%}
<link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
<link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
<link rel="dns-prefetch" href="https://www.google-analytics.com">
<link rel="dns-prefetch" href="https://www.googletagmanager.com">
<link rel="dns-prefetch" href="https://shop.app">
