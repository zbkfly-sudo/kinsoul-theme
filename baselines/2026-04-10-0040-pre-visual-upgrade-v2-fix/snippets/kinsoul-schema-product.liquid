{% comment %}
  Kinsoul Energy — Product Schema (Enhanced)
  Replaces Shopify's auto-generated `{{ product | structured_data }}` with a comprehensive
  Product schema that includes:
    - Standard fields: name, image, description, sku, brand, offers
    - hasMerchantReturnPolicy (Google shows "30-day returns" badge)
    - shippingDetails (Google shows "Free shipping" badge)
    - additionalProperty (material info from metafields)
    - manufacturer, audience, countryOfOrigin, itemCondition

  Usage:
    {% render 'kinsoul-schema-product', product: product %}
  Or pass any product object (used for closest.product on product page,
  section.settings.product on featured product, etc.)
{% endcomment %}

{%- liquid
  unless product
    assign product = closest.product
  endunless

  if product == blank
    break
  endif

  assign current_variant = product.selected_or_first_available_variant
  assign price = current_variant.price | money_without_currency | strip_html
  assign currency = cart.currency.iso_code

  if current_variant.available
    assign availability = 'https://schema.org/InStock'
  else
    assign availability = 'https://schema.org/OutOfStock'
  endif

  assign clean_description = product.description | strip_html | strip_newlines | truncate: 5000
  assign canonical_product_url = shop.url | append: product.url

  assign valid_until = 'now' | date: '%s' | plus: 31536000 | date: '%Y-%m-%d'
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": {{ canonical_product_url | append: '#product' | json }},
  "name": {{ product.title | json }},
  "url": {{ canonical_product_url | json }},
  {%- if product.images.size > 0 %}
  "image": [
    {%- for image in product.images limit: 6 -%}
      {{ image | image_url: width: 1200 | prepend: 'https:' | json }}
      {%- unless forloop.last -%},{%- endunless -%}
    {%- endfor %}
  ],
  {%- endif %}
  "description": {{ clean_description | json }},
  {%- if current_variant.sku != blank %}
  "sku": {{ current_variant.sku | json }},
  {%- endif %}
  "mpn": {{ product.id | append: '-' | append: current_variant.id | json }},
  "productID": {{ product.id | json }},
  "brand": {
    "@type": "Brand",
    "name": "Kinsoul Energy",
    "@id": {{ shop.url | append: '/#organization' | json }}
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "LuKai Trading LLC",
    "@id": {{ shop.url | append: '/#organization' | json }}
  },
  "category": {{ product.type | default: 'Bracelets' | json }},
  "itemCondition": "https://schema.org/NewCondition",
  "countryOfOrigin": "US",
  "audience": {
    "@type": "Audience",
    "audienceType": "Adults"
  },
  {%- comment %} Material info from metafields {% endcomment %}
  {%- assign has_props = false %}
  {%- if product.metafields.custom.stone_type != blank or product.metafields.custom.pearl_type != blank or product.metafields.custom.metal_details != blank or product.metafields.custom.size_fit != blank or product.metafields.custom.stone_story != blank %}
    {%- assign has_props = true %}
  {%- endif %}
  {%- if has_props %}
  "additionalProperty": [
    {%- assign first_prop = true -%}
    {%- if product.metafields.custom.stone_type != blank -%}
      {%- unless first_prop %},{% endunless -%}
      {%- assign first_prop = false %}
    {
      "@type": "PropertyValue",
      "name": "Stone Type",
      "value": {{ product.metafields.custom.stone_type | json }}
    }
    {%- endif -%}
    {%- if product.metafields.custom.pearl_type != blank -%}
      {%- unless first_prop %},{% endunless -%}
      {%- assign first_prop = false %}
    {
      "@type": "PropertyValue",
      "name": "Pearl Type",
      "value": {{ product.metafields.custom.pearl_type | json }}
    }
    {%- endif -%}
    {%- if product.metafields.custom.metal_details != blank -%}
      {%- unless first_prop %},{% endunless -%}
      {%- assign first_prop = false %}
    {
      "@type": "PropertyValue",
      "name": "Metal",
      "value": {{ product.metafields.custom.metal_details | json }}
    }
    {%- endif -%}
    {%- if product.metafields.custom.size_fit != blank -%}
      {%- unless first_prop %},{% endunless -%}
      {%- assign first_prop = false %}
    {
      "@type": "PropertyValue",
      "name": "Size & Fit",
      "value": {{ product.metafields.custom.size_fit | strip_html | strip_newlines | json }}
    }
    {%- endif -%}
    {%- if product.metafields.custom.stone_story != blank -%}
      {%- unless first_prop %},{% endunless -%}
      {%- assign first_prop = false %}
    {
      "@type": "PropertyValue",
      "name": "Stone Story",
      "value": {{ product.metafields.custom.stone_story | strip_html | strip_newlines | json }}
    }
    {%- endif %}
  ],
  {%- endif %}
  {%- if product.material != blank %}
  "material": {{ product.material | json }},
  {%- endif %}
  "keywords": [
    "handmade jewelry",
    "natural pearls",
    "gemstone bracelet",
    "sterling silver",
    {{ product.title | json }}
  ],
  "offers": {
    "@type": "Offer",
    "url": {{ canonical_product_url | json }},
    "priceCurrency": {{ currency | json }},
    "price": {{ price | json }},
    "priceValidUntil": {{ valid_until | json }},
    "availability": {{ availability | json }},
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": "Kinsoul Energy",
      "@id": {{ shop.url | append: '/#organization' | json }}
    },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "US",
      "returnPolicyCountry": "US",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 30,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/ReturnShippingFees",
      "refundType": "https://schema.org/FullRefund"
    },
    "shippingDetails": [
      {
        "@type": "OfferShippingDetails",
        "name": "Free shipping over $200",
        "shippingRate": {
          "@type": "MonetaryAmount",
          "value": "0.00",
          "currency": "USD"
        },
        "shippingDestination": {
          "@type": "DefinedRegion",
          "addressCountry": "US"
        },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": {
            "@type": "QuantitativeValue",
            "minValue": 1,
            "maxValue": 3,
            "unitCode": "DAY"
          },
          "transitTime": {
            "@type": "QuantitativeValue",
            "minValue": 5,
            "maxValue": 10,
            "unitCode": "DAY"
          }
        },
        "eligibleTransactionVolume": {
          "@type": "PriceSpecification",
          "minPrice": "200.00",
          "priceCurrency": "USD"
        }
      },
      {
        "@type": "OfferShippingDetails",
        "name": "Standard US shipping",
        "shippingRate": {
          "@type": "MonetaryAmount",
          "value": "9.00",
          "currency": "USD"
        },
        "shippingDestination": {
          "@type": "DefinedRegion",
          "addressCountry": "US"
        },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": {
            "@type": "QuantitativeValue",
            "minValue": 1,
            "maxValue": 3,
            "unitCode": "DAY"
          },
          "transitTime": {
            "@type": "QuantitativeValue",
            "minValue": 5,
            "maxValue": 10,
            "unitCode": "DAY"
          }
        }
      },
      {
        "@type": "OfferShippingDetails",
        "name": "International shipping",
        "shippingRate": {
          "@type": "MonetaryAmount",
          "value": "9.00",
          "currency": "USD"
        },
        "shippingDestination": {
          "@type": "DefinedRegion",
          "name": "Worldwide"
        },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": {
            "@type": "QuantitativeValue",
            "minValue": 1,
            "maxValue": 3,
            "unitCode": "DAY"
          },
          "transitTime": {
            "@type": "QuantitativeValue",
            "minValue": 7,
            "maxValue": 13,
            "unitCode": "DAY"
          }
        }
      }
    ]
  }
}
</script>
