{%- doc -%}
  Kinsoul Energy — Gift Note
  Renders a "This is a gift" toggle with expandable gift message textarea
  and option to hide pricing. Uses cart.attributes for order-level data.
{%- enddoc -%}

{%- liquid
  assign is_gift = cart.attributes['Gift']
  assign gift_message = cart.attributes['Gift Message']
  assign hide_price = cart.attributes['Hide Price']
-%}

<div class="kinsoul-gift-note">
  <div class="kinsoul-gift-note__toggle">
    <label class="kinsoul-gift-note__checkbox-label" for="kinsoul-gift-toggle">
      <input
        type="checkbox"
        id="kinsoul-gift-toggle"
        name="attributes[Gift]"
        value="Yes"
        form="cart-form"
        {% if is_gift == 'Yes' %}checked{% endif %}
      >
      <span class="kinsoul-gift-note__checkmark">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </span>
      <span class="kinsoul-gift-note__icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
      </span>
      <span class="kinsoul-gift-note__toggle-text">This is a gift</span>
    </label>
  </div>

  <div class="kinsoul-gift-note__content" id="kinsoul-gift-content" {% unless is_gift == 'Yes' %}hidden{% endunless %}>
    <div class="kinsoul-gift-note__message-wrap">
      <label for="kinsoul-gift-message" class="kinsoul-gift-note__label">
        Add a personal message
        <span class="kinsoul-gift-note__optional">(optional)</span>
      </label>
      <textarea
        id="kinsoul-gift-message"
        name="attributes[Gift Message]"
        form="cart-form"
        class="kinsoul-gift-note__textarea"
        placeholder="Happy birthday! Picked this one just for you..."
        maxlength="150"
        rows="3"
      >{{ gift_message }}</textarea>
      <span class="kinsoul-gift-note__char-count">
        <span id="kinsoul-char-current">{{ gift_message | size }}</span>/150
      </span>
    </div>

    <label class="kinsoul-gift-note__checkbox-label kinsoul-gift-note__checkbox-label--small" for="kinsoul-hide-price">
      <input
        type="checkbox"
        id="kinsoul-hide-price"
        name="attributes[Hide Price]"
        value="Yes"
        form="cart-form"
        {% if hide_price == 'Yes' %}checked{% endif %}
      >
      <span class="kinsoul-gift-note__checkmark">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </span>
      <span class="kinsoul-gift-note__hide-text">Don't include pricing information</span>
    </label>

    <p class="kinsoul-gift-note__hint">
      We'll handwrite your message on a card and tuck it inside.
    </p>
  </div>
</div>

{%- comment -%} Hidden input to clear Gift attribute when unchecked {%- endcomment -%}
<input type="hidden" name="attributes[Gift]" value="" form="cart-form" id="kinsoul-gift-hidden">

<script>
  (function() {
    const toggle = document.getElementById('kinsoul-gift-toggle');
    const content = document.getElementById('kinsoul-gift-content');
    const textarea = document.getElementById('kinsoul-gift-message');
    const charCount = document.getElementById('kinsoul-char-current');
    const hiddenInput = document.getElementById('kinsoul-gift-hidden');

    if (!toggle || !content) return;

    toggle.addEventListener('change', function() {
      if (this.checked) {
        content.hidden = false;
        hiddenInput.disabled = true;
        requestAnimationFrame(() => {
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
        });
      } else {
        content.style.maxHeight = '0';
        content.style.opacity = '0';
        hiddenInput.disabled = false;
        setTimeout(() => { content.hidden = true; }, 300);
      }
    });

    // Initialize state
    if (toggle.checked) {
      hiddenInput.disabled = true;
      content.style.maxHeight = content.scrollHeight + 'px';
      content.style.opacity = '1';
    }

    // Character counter
    if (textarea && charCount) {
      textarea.addEventListener('input', function() {
        charCount.textContent = this.value.length;
      });
    }
  })();
</script>
