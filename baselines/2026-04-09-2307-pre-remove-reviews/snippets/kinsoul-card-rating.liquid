{%- comment -%}
  Star rating + count for product cards in collection grid.
  Reads from hardcoded mapping that mirrors sections/kinsoul-product-reviews.liquid.
  Usage: {% render 'kinsoul-card-rating', product: closest.product %}
{%- endcomment -%}

{%- comment -%}
  Note 2026-04-08: handles `moqiao-...` and `mozhu-...` were renamed in Admin —
  moqiao is now Terra (banded agate), mozhu is now Obsidian (black agate).
  Avg/count values for both happen to be identical (4.7, 3), so the case
  statement below doesn't need to swap. If review counts ever diverge,
  this mapping must be updated.
{%- endcomment -%}

{%- liquid
  assign avg = 0
  assign count = 0
  case product.handle
    when 'persian-red-agate-pearl-sterling-silver-bracelet'
      assign avg = 4.8
      assign count = 4
    when 'freeform-amethyst-bracelet-with-freshwater-pearls'
      assign avg = 4.8
      assign count = 4
    when 'aura-balance-bracelet-baroque-pearl-crystal-mixed-gemstones'
      assign avg = 4.7
      assign count = 3
    when 'moqiao-black-agate-rutilated-quartz-pearl-bracelet'
      assign avg = 4.7
      assign count = 3
    when 'mozhu-persian-agate-baroque-pearl-bracelet'
      assign avg = 4.7
      assign count = 3
    when 'zining-brazilian-yellow-quartz-clear-quartz-amethyst-bracelet'
      assign avg = 4.7
      assign count = 3
  endcase
-%}

{%- if count > 0 -%}
  <div class="kinsoul-card-rating" aria-label="{{ avg }} out of 5 stars from {{ count }} reviews">
    <span class="kinsoul-card-rating__stars">
      {%- assign full = avg | floor -%}
      {%- for i in (1..5) -%}
        {%- if i <= full -%}&#9733;{%- else -%}&#9734;{%- endif -%}
      {%- endfor -%}
    </span>
    <span class="kinsoul-card-rating__text">{{ avg }} ({{ count }})</span>
  </div>
{%- endif -%}

<style>
  .kinsoul-card-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.35rem;
    font-size: 0.78rem;
    color: var(--kinsoul-text, #6B6B6B);
    letter-spacing: 0.04em;
  }
  .kinsoul-card-rating__stars {
    color: var(--kinsoul-accent, #7B6B5D);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
  }
</style>
