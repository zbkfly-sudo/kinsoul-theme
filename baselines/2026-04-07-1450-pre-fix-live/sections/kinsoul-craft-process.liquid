{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

<div
  class="kinsoul-craft section-{{ section.id }} color-{{ color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="kinsoul-craft__header">
        {%- if section.settings.subheading != blank -%}
          <p class="kinsoul-craft__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <h2 class="kinsoul-craft__title">{{ section.settings.heading }}</h2>
        <hr class="kinsoul-divider">
        {%- if section.settings.description != blank -%}
          <p class="kinsoul-craft__desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="kinsoul-craft__steps">
      {%- for block in section.blocks -%}
        <div class="kinsoul-craft__step{% if forloop.index == 2 %} kinsoul-craft__step--reverse{% endif %}" {{ block.shopify_attributes }}>
          <div class="kinsoul-craft__step-image">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  widths: '400, 600, 900',
                  sizes: '(max-width: 749px) 100vw, 50vw',
                  class: 'kinsoul-craft__img'
              }}
            {%- else -%}
              <div class="kinsoul-craft__img-placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>
          <div class="kinsoul-craft__step-content">
            <span class="kinsoul-craft__step-number">{{ block.settings.step_number }}</span>
            <h3 class="kinsoul-craft__step-title">{{ block.settings.title }}</h3>
            <p class="kinsoul-craft__step-text">{{ block.settings.description }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .kinsoul-craft__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .kinsoul-craft__subheading {
    font-family: var(--font-secondary--family), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--kinsoul-accent, #7B6B5D);
    margin-bottom: 1rem;
  }

  .kinsoul-craft__title {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    color: var(--color-foreground-heading);
    letter-spacing: 0.03em;
    margin: 0;
  }

  .kinsoul-craft__desc {
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--kinsoul-text, #4A4A4A);
    max-width: 520px;
    margin: 0 auto;
  }

  /* Steps */
  .kinsoul-craft__steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .kinsoul-craft__step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    border-top: 1px solid var(--kinsoul-border, #E0D8CE);
  }

  .kinsoul-craft__step:last-child {
    border-bottom: 1px solid var(--kinsoul-border, #E0D8CE);
  }

  /* Alternate layout: image right, text left */
  .kinsoul-craft__step--reverse {
    direction: rtl;
  }

  .kinsoul-craft__step--reverse > * {
    direction: ltr;
  }

  /* Image */
  .kinsoul-craft__step-image {
    overflow: hidden;
  }

  .kinsoul-craft__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 4 / 3;
    transition: transform 0.6s ease;
  }

  .kinsoul-craft__step:hover .kinsoul-craft__img {
    transform: scale(1.02);
  }

  .kinsoul-craft__img-placeholder {
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--kinsoul-bg-alt, #F0EDE8);
  }

  /* Content */
  .kinsoul-craft__step-content {
    padding: 3rem 3.5rem;
  }

  .kinsoul-craft__step-number {
    display: block;
    font-family: var(--font-heading--family), serif;
    font-size: 0.75rem;
    color: var(--kinsoul-accent, #7B6B5D);
    letter-spacing: 0.15em;
    margin-bottom: 0.75rem;
  }

  .kinsoul-craft__step-title {
    font-family: var(--font-heading--family), serif;
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 400;
    color: var(--kinsoul-heading, #2C2C2C);
    letter-spacing: 0.03em;
    margin: 0 0 1rem;
    line-height: 1.3;
  }

  .kinsoul-craft__step-text {
    font-size: 0.85rem;
    line-height: 1.8;
    color: var(--kinsoul-text, #4A4A4A);
    margin: 0;
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .kinsoul-craft__header {
      margin-bottom: 2.5rem;
    }

    .kinsoul-craft__step,
    .kinsoul-craft__step--reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .kinsoul-craft__step-content {
      padding: 2rem 1.5rem;
    }

    .kinsoul-craft__img {
      aspect-ratio: 3 / 2;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Craft Process",
  "tag": "section",
  "class": "kinsoul-craft-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The Making"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Each Piece Comes to Life"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "craft_step",
      "name": "Craft Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Selected by Hand"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Each stone is individually chosen for its color, texture, and character."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Craft Process",
      "blocks": [
        {
          "type": "craft_step",
          "settings": {
            "step_number": "01",
            "title": "Selected by Hand",
            "description": "We don't order in bulk. Each stone is held, turned, and considered — chosen for its color, clarity, and character. If it doesn't feel right, it doesn't make the cut. The stones you see in your bracelet were picked specifically for that piece."
          }
        },
        {
          "type": "craft_step",
          "settings": {
            "step_number": "02",
            "title": "Assembled One Piece at a Time",
            "description": "Every bracelet is strung by hand — stone by stone, pearl by pearl. The arrangement isn't random; each piece is composed with balance and contrast in mind. It's slow, quiet work — and that's the point."
          }
        },
        {
          "type": "craft_step",
          "settings": {
            "step_number": "03",
            "title": "Checked Before It Leaves",
            "description": "Every finished bracelet is inspected for tension, fit, and finish. We check the cord, adjust the spacing, and make sure it feels right on the wrist. Then it's photographed, placed in its box, and sent on its way to you."
          }
        }
      ]
    }
  ]
}
{% endschema %}
