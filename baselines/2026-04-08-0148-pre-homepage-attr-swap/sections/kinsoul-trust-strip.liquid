{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

<div
  class="kinsoul-trust-strip-section color-{{ color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    <div class="kinsoul-trust-strip">
      {%- for block in section.blocks -%}
        <div class="kinsoul-trust-strip__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon_svg != blank -%}
            {{ block.settings.icon_svg }}
          {%- else -%}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          {%- endif -%}
          <span>{{ block.settings.text }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Strip",
  "tag": "section",
  "class": "kinsoul-trust-strip-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG code"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Strip",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "text": "Natural Pearls & Stones",
            "icon_svg": "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5'><circle cx='12' cy='12' r='10'/><circle cx='12' cy='12' r='4'/></svg>"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "text": "Hand-Finished",
            "icon_svg": "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round'><path d='M6 20C6 20 8 12 14 8C20 4 22 2 22 2'/><path d='M2 22C2 22 10 18 14 14C18 10 20 4 20 4'/></svg>"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "text": "Free Shipping Over $200",
            "icon_svg": "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><rect x='1' y='3' width='15' height='13'/><polygon points='16 8 20 8 23 11 23 16 16 16 16 8'/><circle cx='5.5' cy='18.5' r='2.5'/><circle cx='18.5' cy='18.5' r='2.5'/></svg>"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "text": "Secure Checkout",
            "icon_svg": "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='11' width='18' height='11' rx='2' ry='2'/><path d='M7 11V7a5 5 0 0 1 10 0v4'/></svg>"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "text": "Easy Returns",
            "icon_svg": "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='1 4 1 10 7 10'/><path d='M3.51 15a9 9 0 1 0 2.13-9.36L1 10'/></svg>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
