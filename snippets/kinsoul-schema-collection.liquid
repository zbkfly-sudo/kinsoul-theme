{% comment %}
  Kinsoul Energy — CollectionPage + ItemList Schema
  Renders structured data for collection pages so Google understands
  the page as a product listing with individual product entries.
  Should be rendered in <head> only on collection pages (via theme.liquid).
{% endcomment %}

{%- liquid
  if collection == blank
    break
  endif

  assign collection_url = shop.url | append: collection.url
  assign org_id = shop.url | append: '/#organization'
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": {{ collection.title | json }},
  "url": {{ collection_url | json }},
  {%- if collection.description != blank %}
  "description": {{ collection.description | strip_html | strip_newlines | truncate: 5000 | json }},
  {%- endif %}
  {%- if collection.image %}
  "image": {{ collection.image | image_url: width: 1200 | prepend: 'https:' | json }},
  {%- endif %}
  "isPartOf": {
    "@type": "WebSite",
    "@id": {{ shop.url | append: '/#website' | json }}
  },
  "provider": {
    "@type": "Organization",
    "@id": {{ org_id | json }}
  },
  "mainEntity": {
    "@type": "ItemList",
    "name": {{ collection.title | json }},
    "url": {{ collection_url | json }},
    "numberOfItems": {{ collection.products_count }},
    "itemListElement": [
      {%- for product in collection.products limit: 50 -%}
        {%- liquid
          assign product_url = shop.url | append: product.url
          assign variant = product.selected_or_first_available_variant
          assign product_price = variant.price | money_without_currency | strip_html
          if variant.available
            assign product_availability = 'https://schema.org/InStock'
          else
            assign product_availability = 'https://schema.org/OutOfStock'
          endif
        -%}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "item": {
            "@type": "Product",
            "name": {{ product.title | json }},
            "url": {{ product_url | json }},
            {%- if product.featured_image %}
            "image": {{ product.featured_image | image_url: width: 800 | prepend: 'https:' | json }},
            {%- endif %}
            "brand": {
              "@type": "Brand",
              "name": "Kinsoul Energy"
            },
            "offers": {
              "@type": "Offer",
              "url": {{ product_url | json }},
              "priceCurrency": {{ cart.currency.iso_code | json }},
              "price": {{ product_price | json }},
              "availability": {{ product_availability | json }}
            }
          }
        }
        {%- unless forloop.last -%},{%- endunless -%}
      {%- endfor %}
    ]
  }
}
</script>
