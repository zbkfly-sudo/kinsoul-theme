{% comment %}
  Kinsoul Energy — Organization + WebSite Schema
  Renders the brand-level structured data used across the entire site.
  Should be rendered in <head> on every page (via theme.liquid).
  Includes:
    - Organization (brand identity, founder, contact, social, payment)
    - WebSite (with SearchAction for Google Sitelinks search box)
  Linked together via @id references for a clean semantic graph.
{% endcomment %}

{%- liquid
  assign brand_name = 'Kinsoul Energy'
  assign brand_description = 'Handmade bracelets crafted from 100% natural pearls and hand-selected gemstones — meaningful jewelry designed to be worn every day.'
  assign brand_email = 'hello@kinsoulenergy.com'
  assign brand_slogan = 'Jewelry Born from the Earth'
  assign brand_founder = 'LU'
  assign brand_founding_date = '2018'
  assign instagram_url = 'https://www.instagram.com/kinsoulenergy/'
  assign org_id = shop.url | append: '/#organization'
  assign website_id = shop.url | append: '/#website'
  if settings.logo != blank
    assign logo_url = settings.logo | image_url: width: 500 | prepend: 'https:'
  else
    assign logo_url = ''
  endif
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": {{ org_id | json }},
      "name": {{ brand_name | json }},
      "alternateName": "Kinsoul",
      "legalName": "LuKai Trading LLC",
      "url": {{ shop.url | append: '/' | json }},
      {%- if logo_url != blank %}
      "logo": {
        "@type": "ImageObject",
        "url": {{ logo_url | json }},
        "width": 500,
        "height": 500
      },
      "image": {{ logo_url | json }},
      {%- endif %}
      "description": {{ brand_description | json }},
      "slogan": {{ brand_slogan | json }},
      "email": {{ brand_email | json }},
      "founder": {
        "@type": "Person",
        "name": {{ brand_founder | json }}
      },
      "foundingDate": {{ brand_founding_date | json }},
      "foundingLocation": {
        "@type": "Place",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "US",
          "addressRegion": "CA"
        }
      },
      "knowsLanguage": ["en", "en-US"],
      "knowsAbout": [
        "Handmade jewelry",
        "Natural gemstones",
        "Freshwater pearls",
        "Sterling silver bracelets",
        "Meaningful jewelry"
      ],
      "areaServed": [
        { "@type": "Country", "name": "United States" },
        { "@type": "Place", "name": "Worldwide" }
      ],
      "currenciesAccepted": "USD",
      "paymentAccepted": "Visa, Mastercard, American Express, Discover, Shop Pay, Apple Pay, Google Pay, PayPal",
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "email": {{ brand_email | json }},
          "availableLanguage": ["English"],
          "areaServed": ["US", "Worldwide"]
        }
      ],
      "sameAs": [
        {{ instagram_url | json }}
      ]
    },
    {
      "@type": "WebSite",
      "@id": {{ website_id | json }},
      "url": {{ shop.url | append: '/' | json }},
      "name": {{ brand_name | json }},
      "description": {{ brand_description | json }},
      "publisher": { "@id": {{ org_id | json }} },
      "inLanguage": "en-US",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "{{ shop.url }}/search?q={% raw %}{search_term_string}{% endraw %}"
        },
        "query-input": "required name=search_term_string"
      }
    }
  ]
}
</script>
