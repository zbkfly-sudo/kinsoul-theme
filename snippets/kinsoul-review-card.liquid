{%- comment -%}
  Single review card used by PDP review section.
  Params:
    image_filename — string, filename in Settings → Files (e.g. 'review-01-ember-jasmine.png')
    rating         — int 1-5
    text           — string
    author         — string
    date           — string (e.g. 'March 2026')
    verified       — bool
{%- endcomment -%}

<article class="kinsoul-pdp-review" itemprop="review" itemscope itemtype="https://schema.org/Review">
  <meta itemprop="datePublished" content="{{ date }}">
  <div itemprop="author" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content="{{ author }}">
  </div>
  <div itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
    <meta itemprop="ratingValue" content="{{ rating }}">
    <meta itemprop="bestRating" content="5">
  </div>

  {%- if image_filename != blank -%}
    <div class="kinsoul-pdp-review__image">
      <img
        src="{{ image_filename | file_img_url: '400x' }}"
        srcset="
          {{ image_filename | file_img_url: '200x' }} 200w,
          {{ image_filename | file_img_url: '400x' }} 400w,
          {{ image_filename | file_img_url: '600x' }} 600w
        "
        sizes="(max-width: 749px) 45vw, 280px"
        alt="Customer review by {{ author }}"
        loading="lazy"
        decoding="async"
        width="400"
        height="500"
      >
    </div>
  {%- endif -%}

  <div class="kinsoul-pdp-review__body">
    <div class="kinsoul-pdp-review__stars" aria-label="{{ rating }} out of 5 stars">
      {%- for i in (1..5) -%}
        {%- if i <= rating -%}&#9733;{%- else -%}&#9734;{%- endif -%}
      {%- endfor -%}
    </div>
    <p class="kinsoul-pdp-review__text" itemprop="reviewBody">{{ text }}</p>
    <p class="kinsoul-pdp-review__meta">
      <span class="kinsoul-pdp-review__author">{{ author }}</span>
      <span class="kinsoul-pdp-review__sep">·</span>
      <span class="kinsoul-pdp-review__date">{{ date }}</span>
      {%- if verified -%}
        <span class="kinsoul-pdp-review__sep">·</span>
        <span class="kinsoul-pdp-review__verified">Verified buyer</span>
      {%- endif -%}
    </p>
  </div>
</article>
