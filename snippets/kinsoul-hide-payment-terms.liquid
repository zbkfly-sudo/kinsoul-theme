{%- comment -%}
  Hide Shopify's auto-injected "deferred / subscription / recurring purchase"
  consent checkbox and label.

  WHY: Shopify's payment_button filter (Shop Pay button) auto-inserts a
  consent checkbox + disclaimer on PDPs. For our store all products are
  one-time purchases (no selling plans), so this disclaimer is misleading
  and looks like a subscription scam to first-time visitors. Per the
  diagnostic report this was the single biggest conversion killer.

  HOW IT WORKS:
  1. CSS hides the consent wrapper visually.
  2. JS auto-checks the checkbox + removes the `required` attribute so
     the form still submits cleanly. Runs once on DOMContentLoaded and
     keeps watching via MutationObserver because Shopify re-renders the
     Shop Pay area on variant changes.

  IF YOU EVER ADD REAL SUBSCRIPTION PRODUCTS:
  Remove the {% render 'kinsoul-hide-payment-terms' %} call from
  layout/theme.liquid, or this snippet will hide the legitimate consent
  text on subscription products too.
{%- endcomment -%}

<style>
  /* Shopify-injected consent wrapper — multiple selectors for safety */
  .shopify-payment-terms,
  shopify-payment-terms,
  .product-form .shopify-payment-terms,
  [id^="agree-to-terms"],
  label[for^="agree-to-terms"],
  .installments .shopify-payment-terms,
  .shopify-payment-button + .shopify-payment-terms,
  /* The wrapper Shopify adds inside the Shop Pay button block */
  .shopify-cleanslate .shopify-payment-button > div:has([id^="agree-to-terms"]) {
    display: none !important;
    visibility: hidden !important;
    height: 0 !important;
    width: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }
</style>

<script>
  (function() {
    function neutralizeConsent(root) {
      var checkboxes = (root || document).querySelectorAll(
        'input[id^="agree-to-terms"], input[type="checkbox"][required][id*="terms"]'
      );
      checkboxes.forEach(function(cb) {
        try {
          cb.removeAttribute('required');
          cb.checked = true;
          cb.dispatchEvent(new Event('change', { bubbles: true }));
        } catch (e) {}
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { neutralizeConsent(); });
    } else {
      neutralizeConsent();
    }

    // Shopify re-renders Shop Pay button on variant change → keep watching
    var observer = new MutationObserver(function(mutations) {
      for (var i = 0; i < mutations.length; i++) {
        if (mutations[i].addedNodes && mutations[i].addedNodes.length) {
          neutralizeConsent();
          break;
        }
      }
    });
    if (document.body) {
      observer.observe(document.body, { childList: true, subtree: true });
    } else {
      document.addEventListener('DOMContentLoaded', function() {
        observer.observe(document.body, { childList: true, subtree: true });
      });
    }
  })();
</script>
